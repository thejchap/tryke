{
  "name": "tryke-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "trustedDependencies": [
    "wasm-pack"
  ],
  "scripts": {
    "wasm": "wasm-pack build ../crates/tryke_wasm --target web --out-dir ../../playground/src/wasm/pkg",
    "predev": "bun run wasm",
    "prebuild": "bun run wasm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.52.2",
    "react-resizable-panels": "^2.1.7",
    "@dagrejs/dagre": "^1.1.4",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.7",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.3.5",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1",
    "wasm-pack": "0.15.0"
  }
}
